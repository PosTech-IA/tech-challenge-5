# Railway Environment Variables Template
# Copy these to Railway project environment variables (DO NOT commit the actual file with real values)

# ===== SECURITY CREDENTIALS =====
# Generate new values using: openssl rand -hex 32 (JWT_SECRET) or openssl rand -hex 16 (MinIO)

JWT_SECRET=6eb1c23018e715fc8bc37dcdf22f21dab179bfe6dcf5d5358971e0f532cdd513
MINIO_ACCESS_KEY=c2e807c9843352d4d0b510f0287bf0d4
MINIO_SECRET_KEY=80710a109b1ded3ad9c661567a68d3c1

# ===== ANTHROPIC API KEY =====
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-actual-key-here...

# ===== DATABASE & CACHE (Auto-provided by Railway, DO NOT change) =====
# These will be automatically set by Railway when you add PostgreSQL and Redis services
# DATABASE_URL=postgresql://user:password@host:5432/db
# REDIS_URL=redis://user:password@host:6379

# ===== MINIO ENDPOINT (Keep as is for Railway deployment) =====
# When deployed on Railway, this will be the service name
MINIO_ENDPOINT=minio:9000

# ===== CORS CONFIGURATION =====
# Frontend origin(s) allowed to access the API
# For production: use your deployed frontend domain
# For local development: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=https://tech-challenge-5-front.vercel.app
